{
  "compilerOptions": {
    "target": "es2020",                         /* Versão moderna compatível com Node 16+ */
    "module": "commonjs",
    "rootDir": "src/src",                      /* Origem real dos arquivos TS */
    "outDir": "dist",                           /* Saída da compilação JS */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src/src/**/*.ts",
    "src/src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
